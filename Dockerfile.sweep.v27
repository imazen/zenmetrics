# Dockerfile.sweep.v27 — orchestrator-aware sweep image.
#
# Builds on v26's layer plan (collapsed single-file image, CUDA NVRTC +
# cudart 12-6 + pyarrow + cuda_dlsym_stub + zenfleet-sweep + zenfleet-vastai).
# v27 deltas:
#
#   1. zenmetrics binary built with the new `orchestrator` feature set
#      (`orchestrator,orchestrator-cuda,orchestrator-cpu-all`) so the
#      `--use-orchestrator` flag is functional. Adds ~30 MB to the
#      binary for the cvvdp-cpu + ssimulacra2 + dssim-core + butteraugli
#      + zensim reference adapters; OOM fallback ladder now reaches
#      CPU backends on every metric except iwssim.
#   2. New `/usr/local/bin/onstart_orchestrator.sh` that:
#        a. Hydrates env from `/proc/1/environ`.
#        b. Optionally fetches a fleet-shared `capability_<hash>.toml`
#           from R2 so the worker skips the local warm() bench
#           (saves ~30 s per box on cold boots).
#        c. Drives `zenmetrics sweep --use-orchestrator ...` on the
#           claimed chunk.
#      Operator overrides via `--entrypoint /usr/local/bin/onstart_orchestrator.sh`.
#   3. ENV var `ZENMETRICS_CACHE_DIR=/root/.cache/zenmetrics` so a host
#      mount can persist the capability cache across container
#      restarts. Workers without the mount fall through to a
#      container-local cache (lost on restart but still valid for the
#      duration of the run).
#
# v27 keeps every v26 entrypoint as a fallback target. The default
# ENTRYPOINT is unchanged (zenfleet-sweep via run_with_error_trap).
# Operators that want the orchestrator path explicitly pass
# `--entrypoint /usr/local/bin/onstart_orchestrator.sh`.
#
# Build (from zenmetrics repo root):
#
#   CUDARC_CUDA_VERSION=12000 cargo build --release -p zenmetrics-cli \
#       --no-default-features \
#       --features 'sweep,png,gpu,gpu-cuda,gpu-cpu,orchestrator,orchestrator-cuda,orchestrator-cpu-all'
#   cp target/release/zenmetrics ./zenmetrics
#
#   cargo build --release -p zenfleet-sweep --features vastai
#   cp target/release/zenfleet-sweep ./zenfleet-sweep
#
#   cargo build --release -p zenfleet-vastai --features inline-sweep
#   cp target/release/zenfleet-vastai ./zenfleet-vastai
#
#   docker build -f Dockerfile.sweep.v27 \
#       --build-arg ZEN_METRICS_BINARY=./zenmetrics \
#       --build-arg ZEN_SWEEP_WORKER_BINARY=./zenfleet-sweep \
#       --build-arg VASTAI_FLEET_BINARY=./zenfleet-vastai \
#       -t ghcr.io/imazen/zenmetrics-sweep:v27-$(git rev-parse --short HEAD) \
#       -t ghcr.io/imazen/zenmetrics-sweep:v27 \
#       .
#
# Layer plan (cheap-changes-rarely → expensive-changes-often, identical
# to v26's plan plus the L8 binary's new orchestrator feature set):
#
#   L1 ubuntu:24.04                       ~80 MB
#   L2 stable apt deps                    ~150 MB
#   L3 pyarrow via pip                    ~70 MB
#   L4 CUDA runtime (NVRTC + cudart 12-6) ~250 MB
#   L5 CUDA dev headers                   ~30 MB
#   L6 helpers (s5cmd + jq)               ~18 MB
#   L7 cuda_dlsym_stub.so                 ~15 KB
#   L8 zenmetrics binary (orchestrator)  ~310 MB  (+30 MB vs v26)
#   L9 zenfleet-sweep + zenfleet-vastai    ~10 MB
#   L10 onstart + worker scripts          ~50 KB
#   L11 ENV + LABELs + ENTRYPOINT         0 B
#
# Bake-everything discipline (per CLAUDE.md "Remote / Fleet Images"):
#   - NO apt-install at boot. Every binary + lib is baked here.
#   - NO pip install at boot. pyarrow is baked at L3.
#   - NO cargo build at runtime. All Rust binaries are pre-built and
#     COPY'd in.

FROM ubuntu:24.04

LABEL org.opencontainers.image.source="https://github.com/imazen/zenmetrics"
LABEL org.opencontainers.image.description="zenmetrics sweep worker (v27: orchestrator-aware; zenmetrics built with orchestrator,cpu-all; new onstart_orchestrator.sh entrypoint)"
LABEL org.opencontainers.image.licenses="AGPL-3.0-or-later"

ENV DEBIAN_FRONTEND=noninteractive

# ── L2: stable apt deps ─────────────────────────────────────────────────
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg \
        libssl3 \
        python3 python3-pip \
        gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# ── L3: pyarrow via pip ─────────────────────────────────────────────────
RUN pip3 install --quiet --break-system-packages --no-cache-dir \
        'pyarrow>=15.0,<22.0' \
    && python3 -c "import pyarrow.parquet as pq; print('pyarrow', pq.__doc__.split()[0] if pq.__doc__ else 'OK')"

# ── L4 + L5: CUDA NVRTC + cudart 12-6 + dev headers ─────────────────────
RUN export PATH="/usr/local/sbin:/usr/sbin:/sbin:${PATH}" \
    && curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb \
        -o /tmp/cuda-keyring.deb \
    && dpkg -i /tmp/cuda-keyring.deb \
    && rm /tmp/cuda-keyring.deb \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends \
        cuda-nvrtc-12-6 cuda-cudart-12-6 cuda-cudart-dev-12-6 \
    && rm -rf /var/lib/apt/lists/* \
    && echo "/usr/local/cuda-12.6/lib64" > /etc/ld.so.conf.d/cuda-12.6.conf \
    && ldconfig \
    && ln -sf /usr/local/cuda-12.6 /usr/local/cuda \
    && test -f /usr/local/cuda/include/cuda_runtime.h \
    && test -f /usr/local/cuda/lib64/libcudart.so.12 \
    && ldconfig -p | grep -q libnvrtc.so.12

# ── L6: helpers (s5cmd + jq) ────────────────────────────────────────────
RUN curl -fsSL "https://github.com/peak/s5cmd/releases/download/v2.2.2/s5cmd_2.2.2_Linux-64bit.tar.gz" \
        -o /tmp/s5cmd.tgz \
    && tar xzf /tmp/s5cmd.tgz -C /usr/local/bin s5cmd \
    && rm /tmp/s5cmd.tgz \
    && chmod +x /usr/local/bin/s5cmd \
    && curl -fsSL "https://github.com/jqlang/jq/releases/download/jq-1.7.1/jq-linux-amd64" \
        -o /usr/local/bin/jq \
    && chmod +x /usr/local/bin/jq

# ── L7: cuda_dlsym_stub.so LD_PRELOAD shim ──────────────────────────────
COPY scripts/sweep/cuda_dlsym_stub.c /tmp/cuda_dlsym_stub.c
RUN gcc -shared -fPIC -O2 -o /usr/local/lib/cuda_dlsym_stub.so \
        /tmp/cuda_dlsym_stub.c -ldl \
    && rm /tmp/cuda_dlsym_stub.c \
    && test -s /usr/local/lib/cuda_dlsym_stub.so \
    && nm -D --defined-only /usr/local/lib/cuda_dlsym_stub.so 2>/dev/null \
        | grep -q ' T dlsym$' \
        || (echo "v27 cuda_dlsym_stub.so missing exported dlsym override" >&2 && exit 1) \
    && echo "v27 cuda_dlsym_stub universal cu* shim baked"

# ── Environment for the runtime worker ──────────────────────────────────
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/nvidia/lib:/usr/local/nvidia/lib64 \
    CUDA_PATH=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:/usr/local/sbin:/usr/sbin:/sbin:/usr/local/bin:/usr/bin:/bin \
    LD_PRELOAD=/usr/local/lib/cuda_dlsym_stub.so \
    WORKDIR=/workspace/sweep \
    ZENMETRICS_CACHE_DIR=/root/.cache/zenmetrics

WORKDIR /workspace/sweep

# Smoke: every base-layer package must be importable / runnable before
# we put expensive binaries on top.
RUN python3 -c "import pyarrow.parquet as pq; print('pyarrow OK')" \
    && s5cmd version \
    && jq --version \
    && ldconfig -p | grep -q libnvrtc.so.12 \
    && test -f /usr/local/lib/cuda_dlsym_stub.so \
    && echo "v27 base-layer smoke passed"

# ── L8: zenmetrics binary (orchestrator features) ──────────────────────
#
# Built with `--features orchestrator,orchestrator-cuda,orchestrator-cpu-all`
# so the per-cell OOM fallback ladder reaches every supported CPU
# reference (cvvdp-cpu, ssimulacra2, dssim-core, butteraugli, zensim;
# iwssim has no clean CPU reference and surfaces an honest error per
# `crates/zenmetrics-orchestrator/docs/CPU_BACKENDS.md`).
ARG ZEN_METRICS_BINARY=./zenmetrics
COPY --chmod=0755 ${ZEN_METRICS_BINARY} /usr/local/bin/zenmetrics

# Sanity gate: binary runs + the new orchestrator flags are exposed.
RUN /usr/local/bin/zenmetrics --version \
    && /usr/local/bin/zenmetrics --help 2>&1 | grep -q -- '--use-orchestrator' \
    && /usr/local/bin/zenmetrics --help 2>&1 | grep -q -- '--orchestrator-cache' \
    && /usr/local/bin/zenmetrics --help 2>&1 | grep -q -- '--bench-on-start' \
    && /usr/local/bin/zenmetrics --help 2>&1 | grep -q -- '--cpu-features' \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q zensim \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q cvvdp \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q iwssim \
    && /usr/local/bin/zenmetrics score-pairs --help 2>&1 | grep -q pairs-tsv \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenjpeg \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenwebp \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenavif \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenjxl \
    && for sym in cuCtxGetDevice_v2 cuEventElapsedTime_v2 cuCoredumpDeregisterStartCallback cuCoredumpDeregisterCompleteCallback ; do \
        if strings /usr/local/bin/zenmetrics 2>/dev/null | grep -q "^${sym}$"; then \
            echo "v27: ${sym} still referenced -- rebuild with CUDARC_CUDA_VERSION=12000" >&2 ; \
            exit 1 ; \
        fi ; \
    done \
    && echo "v27 zenmetrics smoke + orchestrator-flag check passed"

# Pre-create the cache dir so a host volume can mount cleanly.
RUN mkdir -p /root/.cache/zenmetrics

# ── L9: deployed worker (zenfleet-sweep) + operator CLI (zenfleet-vastai) ─
ARG ZEN_SWEEP_WORKER_BINARY=./zenfleet-sweep
ARG VASTAI_FLEET_BINARY=./zenfleet-vastai
COPY --chmod=0755 ${ZEN_SWEEP_WORKER_BINARY} /usr/local/bin/zenfleet-sweep
COPY --chmod=0755 ${VASTAI_FLEET_BINARY} /usr/local/bin/zenfleet-vastai

RUN /usr/local/bin/zenfleet-sweep --version \
    && /usr/local/bin/zenfleet-sweep --help 2>&1 | grep -q -- '--backend' \
    && /usr/local/bin/zenfleet-vastai --version \
    && /usr/local/bin/zenfleet-vastai --help 2>&1 | grep -q self-destroy \
    && /usr/local/bin/zenfleet-vastai self-destroy --help 2>&1 | grep -q -- '--error-log' \
    && echo "v27 zenfleet-sweep + zenfleet-vastai smoke passed"

# ── L10: onstart + worker scripts (v26 set + new orchestrator entry) ────
COPY --chmod=0755 scripts/sweep/run_with_error_trap.sh           /usr/local/bin/run_with_error_trap.sh
COPY --chmod=0755 scripts/sweep/onstart_unified.sh                /usr/local/bin/onstart_unified.sh
COPY --chmod=0755 scripts/sweep/onstart_feature_backfill.sh       /usr/local/bin/onstart_feature_backfill.sh
COPY --chmod=0755 scripts/sweep/onstart_source_features.sh        /usr/local/bin/onstart_source_features.sh
COPY --chmod=0755 scripts/sweep/onstart_omni_backfill.sh          /usr/local/bin/onstart_omni_backfill.sh
COPY --chmod=0755 scripts/sweep/onstart_cvvdp_backfill_imazen.sh  /usr/local/bin/onstart_cvvdp_imazen.sh
COPY --chmod=0755 scripts/sweep/onstart_cvvdp_backfill.sh         /usr/local/bin/onstart_cvvdp.sh
COPY --chmod=0755 scripts/sweep/onstart_iwssim_backfill_v14.sh    /usr/local/bin/onstart_iwssim.sh
COPY --chmod=0755 scripts/sweep/onstart_iwssim_backfill.sh        /usr/local/bin/onstart_iwssim_v3.sh
COPY --chmod=0755 scripts/sweep/onstart_v3.sh                     /usr/local/bin/zenmetrics-worker
COPY --chmod=0755 scripts/sweep/omni_backfill_chunk_worker.sh     /usr/local/bin/omni_chunk_worker.sh
COPY --chmod=0755 scripts/sweep/cvvdp_backfill_chunk_worker.sh    /usr/local/bin/cvvdp_chunk_worker.sh
COPY --chmod=0755 scripts/sweep/metric_backfill_chunk_worker.sh   /usr/local/bin/metric_chunk_worker.sh
COPY --chmod=0755 scripts/sweep/iwssim_backfill_chunk_worker.sh   /usr/local/bin/iwssim_chunk_worker.sh

# v27 addition: orchestrator-aware onstart.
COPY --chmod=0755 scripts/sweep/onstart_orchestrator.sh           /usr/local/bin/onstart_orchestrator.sh

# Sanity gate the new onstart parses + references the orchestrator flag.
RUN grep -q -- '--use-orchestrator' /usr/local/bin/onstart_orchestrator.sh \
    && grep -q -- '--orchestrator-cache' /usr/local/bin/onstart_orchestrator.sh \
    && bash -n /usr/local/bin/onstart_orchestrator.sh \
    && echo "v27 onstart_orchestrator.sh present + valid"

# ── L11: ENTRYPOINT ─────────────────────────────────────────────────────
#
# Default = same as v26 (cloud-agnostic worker via onstart_unified.sh
# wrapped by the error trap). Orchestrator opt-in is per-invocation via
# --entrypoint /usr/local/bin/onstart_orchestrator.sh.
ENTRYPOINT ["/usr/local/bin/run_with_error_trap.sh", "/usr/local/bin/onstart_unified.sh"]

# Dockerfile.sweep.salad.v1 — SaladCloud deploy image for the zen sweep worker.
#
# Sibling of Dockerfile.sweep.v26 (the vast.ai image). Reuses v26's L1-L8
# VERBATIM (same ubuntu base → apt → pyarrow → CUDA runtime+dev → s5cmd+jq
# → cuda_dlsym_stub → zenmetrics binary), then diverges at L9+:
#
#   L9  : zenfleet-sweep built --features salad-sweep (NOT vastai).
#   L9b : salad-http-job-queue-worker v0.7.0 Go sidecar (baked from the
#         upstream GitHub release tarball — NOT boot-fetched).
#   L10 : entrypoint_salad.sh (launches BOTH the sidecar + the worker).
#   L11 : ENTRYPOINT → entrypoint_salad.sh.
#
# BAKE-EVERYTHING (zensim CLAUDE.md): nothing apt/pip/curl-installed at
# container boot. The sidecar + both binaries + the entrypoint are all
# baked here at image-build time. The entrypoint runs the JOB, not an
# installer.
#
# Architecture (SALAD.md § "why the app speaks HTTP, not gRPC"):
# Salad's managed queue → the `salad-http-job-queue-worker` sidecar
# (gRPC client to Salad's queue) → forwards each job as
# `POST http://localhost:<job.port><job.path>` to the worker's local
# HTTP receiver (`zenfleet_salad::queue::SaladJobQueue`). The HTTP
# response body is read back as the job output. So the image runs the
# sidecar + `zenfleet-sweep worker --backend salad` side-by-side; the
# worker binds the port the sidecar POSTs to (SALAD_JOB_PORT, default
# :80 per the upstream mandelbrot with-shell-script sample).
#
# Layer plan (cheap-changes-rarely → expensive-changes-often):
#
#   ┌──────────────────────────────────────────────────────────────┐
#   │ L1: ubuntu:24.04                       ~80 MB   biennial      │
#   │ L2: stable apt deps                    ~150 MB  per quarter   │
#   │ L3: pyarrow via pip                    ~70 MB   per quarter   │
#   │ L4: CUDA runtime (NVRTC + cudart 12-6) ~250 MB  per CUDA bump │
#   │ L5: CUDA dev headers (cudart-dev-12-6) ~30 MB   per CUDA bump │
#   │ L6: helpers (s5cmd 2.2.2 + jq 1.7.1)   ~18 MB   per quarter   │
#   │ L7: cuda_dlsym_stub.so (compiled here) ~15 KB   rare          │
#   │ L8: zenmetrics binary                 ~280 MB  per code push │
#   │ L9: zenfleet-sweep (salad-sweep)      ~10 MB   per code push │
#   │ L9b: salad-http-job-queue-worker sidecar ~25 MB pinned        │
#   │ L10: entrypoint_salad.sh                ~5 KB   per script    │
#   │ L11: ENV + LABELs + ENTRYPOINT         0 B      ~never        │
#   └──────────────────────────────────────────────────────────────┘
#
# Build (context: zenmetrics dir):
#
#   # 1. zenmetrics binary — IDENTICAL to v26's build (same CUDA pin).
#   CUDARC_CUDA_VERSION=12000 cargo build --release -p zenmetrics-cli \
#       --no-default-features --features 'sweep,png,gpu,gpu-cuda,gpu-cpu'
#   cp target/release/zenmetrics ./zenmetrics
#
#   # 2. zenfleet-sweep --features salad-sweep (the Salad glue + the
#   #    shared inline encode+score compute; same GPU tree as vastai).
#   cargo build --release -p zenfleet-sweep --features salad-sweep
#   cp target/release/zenfleet-sweep ./zenfleet-sweep
#
#   # 3. Build the image:
#   docker build -f Dockerfile.sweep.salad.v1 \
#       --build-arg ZEN_METRICS_BINARY=./zenmetrics \
#       --build-arg ZEN_SWEEP_WORKER_BINARY=./zenfleet-sweep \
#       -t ghcr.io/imazen/zenmetrics-sweep-salad:v1-$(git rev-parse --short HEAD) \
#       -t ghcr.io/imazen/zenmetrics-sweep-salad:v1 \
#       .
#
# Run: the Salad container group points at this image. The ENTRYPOINT
# launches the sidecar + `zenfleet-sweep worker --backend salad`.
# Set SALAD_JOB_PORT in the container group env to the group's
# `queue_connection.port` (the worker binds it; the sidecar POSTs to it).

FROM ubuntu:24.04

LABEL org.opencontainers.image.source="https://github.com/imazen/zenmetrics"
LABEL org.opencontainers.image.description="zenmetrics SaladCloud sweep worker (salad.v1: v26 base layers + zenfleet-sweep --features salad-sweep + baked salad-http-job-queue-worker v0.7.0 sidecar + dual-launch entrypoint). HTTP job receiver fed by the sidecar; BYO R2/S3."
LABEL org.opencontainers.image.licenses="AGPL-3.0-or-later"

ENV DEBIAN_FRONTEND=noninteractive

# ── L2: stable apt deps ─────────────────────────────────────────────────
# VERBATIM from Dockerfile.sweep.v26. gcc + libc6-dev for cuda_dlsym_stub.
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg \
        libssl3 \
        python3 python3-pip \
        gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# ── L3: pyarrow via pip ─────────────────────────────────────────────────
# VERBATIM from Dockerfile.sweep.v26.
RUN pip3 install --quiet --break-system-packages --no-cache-dir \
        'pyarrow>=15.0,<22.0' \
    && python3 -c "import pyarrow.parquet as pq; print('pyarrow', pq.__doc__.split()[0] if pq.__doc__ else 'OK')"

# ── L4 + L5: CUDA NVRTC + cudart 12-6 + dev headers ─────────────────────
# VERBATIM from Dockerfile.sweep.v26. Pinned 12-6 (matches every host's
# libcuda compat-shim support). cubecl-cuda dlopens libnvrtc.so.12 +
# emits #include <cuda_runtime.h> so the dev headers are required.
RUN export PATH="/usr/local/sbin:/usr/sbin:/sbin:${PATH}" \
    && curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb \
        -o /tmp/cuda-keyring.deb \
    && dpkg -i /tmp/cuda-keyring.deb \
    && rm /tmp/cuda-keyring.deb \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends \
        cuda-nvrtc-12-6 cuda-cudart-12-6 cuda-cudart-dev-12-6 \
    && rm -rf /var/lib/apt/lists/* \
    && echo "/usr/local/cuda-12.6/lib64" > /etc/ld.so.conf.d/cuda-12.6.conf \
    && ldconfig \
    && ln -sf /usr/local/cuda-12.6 /usr/local/cuda \
    && test -f /usr/local/cuda/include/cuda_runtime.h \
    && test -f /usr/local/cuda/lib64/libcudart.so.12 \
    && ldconfig -p | grep -q libnvrtc.so.12

# ── L6: helpers (s5cmd + jq) ────────────────────────────────────────────
# VERBATIM from Dockerfile.sweep.v26. Static binaries, pinned versions.
RUN curl -fsSL "https://github.com/peak/s5cmd/releases/download/v2.2.2/s5cmd_2.2.2_Linux-64bit.tar.gz" \
        -o /tmp/s5cmd.tgz \
    && tar xzf /tmp/s5cmd.tgz -C /usr/local/bin s5cmd \
    && rm /tmp/s5cmd.tgz \
    && chmod +x /usr/local/bin/s5cmd \
    && curl -fsSL "https://github.com/jqlang/jq/releases/download/jq-1.7.1/jq-linux-amd64" \
        -o /usr/local/bin/jq \
    && chmod +x /usr/local/bin/jq

# ── L7: cuda_dlsym_stub.so LD_PRELOAD shim ──────────────────────────────
# VERBATIM from Dockerfile.sweep.v26. Catches cudarc-0.19.4 eager Lib::new
# missing-symbol panics on heterogeneous consumer-GPU driver pools (Salad
# nodes are commodity GPUs, so this defense-in-depth matters even more
# than on vast.ai). Same source file the v26 image compiles.
COPY scripts/sweep/cuda_dlsym_stub.c /tmp/cuda_dlsym_stub.c
RUN gcc -shared -fPIC -O2 -o /usr/local/lib/cuda_dlsym_stub.so \
        /tmp/cuda_dlsym_stub.c -ldl \
    && rm /tmp/cuda_dlsym_stub.c \
    && test -s /usr/local/lib/cuda_dlsym_stub.so \
    && nm -D --defined-only /usr/local/lib/cuda_dlsym_stub.so 2>/dev/null \
        | grep -q ' T dlsym$' \
        || (echo "salad.v1 cuda_dlsym_stub.so missing exported dlsym override" >&2 && exit 1) \
    && echo "salad.v1 cuda_dlsym_stub universal cu* shim baked"

# ── Environment for the runtime worker ──────────────────────────────────
# VERBATIM from Dockerfile.sweep.v26 (LD_LIBRARY_PATH for libnvrtc dlopen,
# LD_PRELOAD wires the cuda_dlsym_stub into every process, PATH includes
# /sbin). WORKDIR differs (salad workspace) and SALAD_JOB_PORT documents
# the bind-port contract — it defaults to :80 in the worker when unset,
# but the operator should set it to the container group's
# queue_connection.port. Left unset here so it MUST be supplied by the
# container-group env (fail-loud is the worker binding :80 by default;
# the entrypoint logs the effective port).
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/nvidia/lib:/usr/local/nvidia/lib64 \
    CUDA_PATH=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:/usr/local/sbin:/usr/sbin:/sbin:/usr/local/bin:/usr/bin:/bin \
    LD_PRELOAD=/usr/local/lib/cuda_dlsym_stub.so \
    WORKDIR=/workspace/salad-sweep

WORKDIR /workspace/salad-sweep

# Smoke: every base-layer package must be importable / runnable before
# we put expensive binaries on top.
RUN python3 -c "import pyarrow.parquet as pq; print('pyarrow OK')" \
    && s5cmd version \
    && jq --version \
    && ldconfig -p | grep -q libnvrtc.so.12 \
    && test -f /usr/local/lib/cuda_dlsym_stub.so \
    && echo "salad.v1 base-layer smoke passed"

# ── L8: zenmetrics binary ──────────────────────────────────────────────
# IDENTICAL to v26 (same artifact, same CUDARC_CUDA_VERSION=12000 build).
# The Salad worker's inline encode+score compute calls the same
# zenmetrics-cli lib path the vast.ai worker does.
ARG ZEN_METRICS_BINARY=./zenmetrics
COPY --chmod=0755 ${ZEN_METRICS_BINARY} /usr/local/bin/zenmetrics

# Sanity gate (mirrors v26): binary runs + every metric/CLI surface is
# wired + the cudarc-12000 bind pin held (no _v2 panic symbols slipped
# back in).
RUN /usr/local/bin/zenmetrics --version \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q zensim \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q cvvdp \
    && /usr/local/bin/zenmetrics list-metrics 2>&1 | grep -q iwssim \
    && /usr/local/bin/zenmetrics score-pairs --help 2>&1 | grep -q pairs-tsv \
    && /usr/local/bin/zenmetrics score-pairs --help 2>&1 | grep -q allow-small-images \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenjpeg \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenwebp \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenavif \
    && /usr/local/bin/zenmetrics sweep --help 2>&1 | grep -q zenjxl \
    && for sym in cuCtxGetDevice_v2 cuEventElapsedTime_v2 cuCoredumpDeregisterStartCallback cuCoredumpDeregisterCompleteCallback ; do \
        if strings /usr/local/bin/zenmetrics 2>/dev/null | grep -q "^${sym}$"; then \
            echo "salad.v1: ${sym} still referenced -- rebuild with CUDARC_CUDA_VERSION=12000" >&2 ; \
            exit 1 ; \
        fi ; \
    done \
    && echo "salad.v1 zenmetrics smoke + cudarc-bind check passed"

# ── L9: deployed worker (zenfleet-sweep, --features salad-sweep) ───────
#
# The cloud-agnostic deployed worker, built for the SALAD backend
# (`--features salad-sweep`): the Salad JobQueue/CredentialSource/
# WorkerHost/BlobStorage/Heartbeat glue + the shared inline encode+score
# compute (same GPU tree as vastai's inline-sweep). Invoked as
# `zenfleet-sweep worker --backend salad`. The worker binds a local
# HTTP receiver (SaladJobQueue) on SALAD_JOB_PORT (default :80) that the
# sidecar POSTs each queue job to.
ARG ZEN_SWEEP_WORKER_BINARY=./zenfleet-sweep
COPY --chmod=0755 ${ZEN_SWEEP_WORKER_BINARY} /usr/local/bin/zenfleet-sweep

# Sanity gate: the worker exposes the worker subcommand + the --backend
# selector, and `--backend salad` is an accepted value (the salad-sweep
# build compiled the Salad dispatch arm in).
RUN /usr/local/bin/zenfleet-sweep --version \
    && /usr/local/bin/zenfleet-sweep --help 2>&1 | grep -q -- '--backend' \
    && /usr/local/bin/zenfleet-sweep worker --backend salad --help 2>&1 | grep -q -- '--run-id' \
    && /usr/local/bin/zenfleet-sweep worker --backend salad --help 2>&1 | grep -q -- '--chunks-r2' \
    && echo "salad.v1 zenfleet-sweep (salad-sweep) smoke passed"

# ── L9b: salad-http-job-queue-worker sidecar (Go, v0.7.0, x86_64) ────────
#
# The ONLY shipped Salad sidecar binary (SALAD.md). It is the gRPC client
# to Salad's managed queue and forwards each Job { job_id, port, path,
# input } to the worker as `POST http://localhost:<port><path>`, reading
# the HTTP response body back as the job output. Pinned to v0.7.0 (Salad
# nodes are x86_64 only). Baked from the upstream release tarball here at
# IMAGE BUILD time — NEVER boot-fetched (BAKE-EVERYTHING rule). The
# tarball extracts a single `salad-http-job-queue-worker` binary.
ARG SALAD_JOB_QUEUE_WORKER_VERSION=0.7.0
RUN curl -fsSL "https://github.com/SaladTechnologies/salad-cloud-job-queue-worker/releases/download/v${SALAD_JOB_QUEUE_WORKER_VERSION}/salad-http-job-queue-worker_x86_64.tar.gz" \
        -o /tmp/salad-sidecar.tar.gz \
    && tar -C /usr/local/bin -zxpf /tmp/salad-sidecar.tar.gz salad-http-job-queue-worker \
    && rm /tmp/salad-sidecar.tar.gz \
    && chmod 0755 /usr/local/bin/salad-http-job-queue-worker \
    && test -x /usr/local/bin/salad-http-job-queue-worker \
    && echo "salad.v1 salad-http-job-queue-worker v${SALAD_JOB_QUEUE_WORKER_VERSION} sidecar baked"

# ── L9c: cubecl PTX cache config + warmup fixtures ──────────────────────
#
# Tag: :v4-kernel-cache and later. Earlier image versions (:v1-:v3) shipped
# without these and paid the full NVRTC compile cost on every cold start.
#
# By default cubecl's CompilationConfig.cache = None — the on-disk PTX
# cache code path compiles, but is never enabled. A `cubecl.toml` in WORKDIR
# turns it on (cubecl walks up from cwd looking for cubecl.toml / CubeCL.toml
# per RuntimeConfig::from_current_dir). With `cache = { file = "/var/cache/
# cubecl" }`, cubecl-cuda writes compiled PTX bytes (Vec<c_char> + entrypoint
# name) to /var/cache/cubecl/cuda/<cubecl-common-ver>/<sha>/sm_<arch>/<driver>
# /ptx.json.log, keyed by KernelId::stable_hash. The patched cache key
# (zenforks-cubecl-cuda 0.10.1, see crates/zenmetrics-api/docs/CUBECL_
# PERSISTENT_PTX_CACHE_PATCH.md) makes the path per-arch so Salad's
# heterogeneous GPU fleet (RTX 3060 sm_86 vs RTX 4090 sm_89 etc) gets its
# own per-node cache.
COPY scripts/sweep/cubecl.toml /workspace/salad-sweep/cubecl.toml
RUN test -s /workspace/salad-sweep/cubecl.toml \
    && grep -q '/var/cache/cubecl' /workspace/salad-sweep/cubecl.toml \
    && mkdir -p /var/cache/cubecl \
    && echo "salad.v1 cubecl.toml + cache dir baked"

# Warmup fixtures: small (64x64) for the default 5 GPU metrics, large
# (256x256) for iwssim-gpu's >=176px requirement. Baked under
# /opt/zen/warmup; the warmup script reads from there.
COPY crates/zenmetrics-cli/tests/fixtures/ref_64.png         /opt/zen/warmup/ref_64.png
COPY crates/zenmetrics-cli/tests/fixtures/dist_noisy_64.png  /opt/zen/warmup/dist_noisy_64.png
COPY crates/zenmetrics-cli/tests/fixtures/ref_256.png        /opt/zen/warmup/ref_256.png
COPY crates/zenmetrics-cli/tests/fixtures/dist_noisy_256.png /opt/zen/warmup/dist_noisy_256.png
RUN test -s /opt/zen/warmup/ref_64.png \
    && test -s /opt/zen/warmup/dist_noisy_64.png \
    && test -s /opt/zen/warmup/ref_256.png \
    && test -s /opt/zen/warmup/dist_noisy_256.png \
    && echo "salad.v1 warmup fixtures baked"

COPY --chmod=0755 scripts/sweep/warmup_kernels.sh /usr/local/bin/warmup_kernels.sh
RUN test -x /usr/local/bin/warmup_kernels.sh && echo "salad.v1 warmup script baked"

# ── L10: Salad entrypoint ────────────────────────────────────────────────
#
# Hydrates env, verifies the baked tools exist (fail-loud-exit-nonzero if
# missing — a broken image must NOT paper over it with a runtime install),
# then runs the kernel-cache warmup pass (idempotent; ~5–30s cold, <1s
# warm), and FINALLY launches BOTH the sidecar and `zenfleet-sweep worker
# --backend salad` concurrently (the upstream with-shell-script pattern).
# NO apt/pip/curl at boot.
COPY --chmod=0755 scripts/sweep/entrypoint_salad.sh /usr/local/bin/entrypoint_salad.sh

# ── L11: ENTRYPOINT ─────────────────────────────────────────────────────
# Salad runs the container with no override; the entrypoint launches the
# sidecar + the HTTP-serving worker. Operators can `--entrypoint
# /usr/local/bin/zenmetrics` for an ad-hoc CLI shell.
ENTRYPOINT ["/usr/local/bin/entrypoint_salad.sh"]

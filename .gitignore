# Repo-root staging for Dockerfile.sweep.vNN precompiled-binary builds.
# The CI workflow downloads the artifact to this path; local builds
# `cp target/release/zenmetrics ./zenmetrics-vNN`. Never commit it.
/zenmetrics
/zenmetrics-v*
/zenfleet-sweep
# Anchor to root: the docker-build artifact at /zenfleet-vastai, NOT
# the source directory crates/zenfleet-vastai/.
/zenfleet-vastai
/zenmetrics
.v4_extract/
/zenfleet-sweep-arm64

# Pre-rename docker-build staging artifacts (old bin names): vastai-fleet
# (now zenfleet-vastai), zen-metrics (now zenmetrics), zen-sweep-worker
# (now zenfleet-sweep). ~495 MB of stray ELF binaries got staged at root
# during the crate rename; untracked + ignored 2026-06-18 so `git add -A`
# can't re-add them.
/vastai-fleet
/zen-metrics
/zen-sweep-worker

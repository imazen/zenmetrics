# Dockerfile.sweep.v15 — thin layer over v14 + self-destroy CLI.
#
# v15 = v14 image (all the heavy lifting: ubuntu + cuda-nvrtc + pyarrow
# + s5cmd + zen-metrics) + a small layer adding:
#   - vastai-fleet binary with new `self-destroy` subcommand
#   - run_with_error_trap.sh wrapper
#   - cvvdp + metric chunk worker scripts (v14 only baked the
#     iwssim worker; cvvdp / generic flows need their own)
#
# Building this image is fast (~5s + ~5 MB push) because the v14
# base layer is already cached on GHCR.
#
# Build (no Rust rebuild — only vastai-fleet, which is ~3 MB):
#
#   cd ~/work/zen/zenmetrics
#   cargo build --release -p vastai-fleet
#   cp target/release/vastai-fleet ./vastai-fleet
#
#   docker build -f Dockerfile.sweep.v15 \
#       --build-arg V14_TAG=v14 \
#       --build-arg VASTAI_FLEET_BINARY=./vastai-fleet \
#       -t ghcr.io/imazen/zen-metrics-sweep:v15-$(git rev-parse --short HEAD) \
#       -t ghcr.io/imazen/zen-metrics-sweep:v15 \
#       .
#
#   docker push ghcr.io/imazen/zen-metrics-sweep:v15-$(git rev-parse --short HEAD)
#   docker push ghcr.io/imazen/zen-metrics-sweep:v15

ARG V14_TAG=v14
FROM ghcr.io/imazen/zen-metrics-sweep:${V14_TAG}

# Curl + cuda-cudart-dev: v14 has cuda-cudart-12-6 runtime but NOT the
# dev headers. cubecl-cuda emits kernels with `#include <cuda_runtime.h>`
# and NVRTC compiles them at launch — without the headers every kernel
# launch fails with InvalidImageSize → 100% NaN rows per chunk (v24
# lesson). Baking the headers here makes the runtime install path in
# onstart_cvvdp_backfill_imazen.sh a no-op (good — matches "BAKE
# EVERYTHING, NEVER APT-INSTALL AT BOOT" per CLAUDE.md).
#
# curl is needed for vastai-fleet self-destroy's REST DELETE call.
#
# NVIDIA cuda-keyring is fetched here at BUILD time (not boot time) so
# the apt install can resolve the cuda-cudart-dev-12-6 package.
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
        curl ca-certificates gnupg gcc libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# Build the cuda_dlsym_stub LD_PRELOAD shim. Routes cudarc 0.19.4's
# lookup of cuCoredumpDeregisterCompleteCallback (removed in CUDA
# 13.x libcuda) to a no-op stub instead of NULL — keeps the cubecl
# device dispatcher alive on modern vast.ai drivers. See the file
# header for safety analysis.
COPY scripts/sweep/cuda_dlsym_stub.c /tmp/cuda_dlsym_stub.c
RUN gcc -shared -fPIC -O2 -o /usr/local/lib/cuda_dlsym_stub.so \
        /tmp/cuda_dlsym_stub.c -ldl \
    && rm /tmp/cuda_dlsym_stub.c \
    && test -f /usr/local/lib/cuda_dlsym_stub.so

# LD_PRELOAD the shim system-wide so every zen-metrics invocation
# in the container inherits it. Operators can override per-process
# by clearing $LD_PRELOAD if they're debugging the symbol path.
ENV LD_PRELOAD=/usr/local/lib/cuda_dlsym_stub.so

# v14 base ships /bin/sh with PATH missing /sbin, which breaks dpkg.
# Prepend the standard sbin dirs for this RUN.
RUN export PATH="/usr/local/sbin:/usr/sbin:/sbin:${PATH}" \
    && curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb \
        -o /tmp/cuda-keyring.deb \
    && dpkg -i /tmp/cuda-keyring.deb \
    && rm /tmp/cuda-keyring.deb \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends cuda-cudart-dev-12-6 \
    && rm -rf /var/lib/apt/lists/* \
    && ldconfig

# Also bake the /sbin PATH for runtime (so onstart's ldconfig probe works).
ENV PATH=/usr/local/sbin:/usr/sbin:/sbin:/usr/local/bin:/usr/bin:/bin

# Sanity: confirm the dev headers landed where the onstart script
# expects, AND the cuda symlink is intact so cubecl's resolver finds
# libcuda_runtime.so / cuda_runtime.h via /usr/local/cuda/.
RUN test -f /usr/local/cuda/include/cuda_runtime.h \
    && test -f /usr/local/cuda/lib64/libcudart.so.12 \
    && ldconfig -p | grep -q libnvrtc.so.12 \
    && echo "v15 cuda dev/runtime sanity passed"

# L5b: vastai-fleet binary (~3 MB). The new self-destroy subcommand
# is what the EXIT trap calls.
ARG VASTAI_FLEET_BINARY=./vastai-fleet
COPY --chmod=0755 ${VASTAI_FLEET_BINARY} /usr/local/bin/vastai-fleet

RUN /usr/local/bin/vastai-fleet --help 2>&1 | grep -q self-destroy \
    && /usr/local/bin/vastai-fleet self-destroy --help 2>&1 | grep -q error-log \
    && echo "L5b vastai-fleet smoke passed"

# L6: scripts. cvvdp + unified worker (v14 only had iwssim) + the new
# error-trap wrapper. Run_with_error_trap is what callers point
# vast.ai's --entrypoint at.
COPY --chmod=0755 scripts/sweep/onstart_cvvdp_backfill_imazen.sh /usr/local/bin/onstart_cvvdp_imazen.sh
COPY --chmod=0755 scripts/sweep/cvvdp_backfill_chunk_worker.sh   /usr/local/bin/cvvdp_chunk_worker.sh
COPY --chmod=0755 scripts/sweep/metric_backfill_chunk_worker.sh  /usr/local/bin/metric_chunk_worker.sh
COPY --chmod=0755 scripts/sweep/run_with_error_trap.sh           /usr/local/bin/run_with_error_trap.sh

LABEL org.opencontainers.image.source="https://github.com/imazen/zenmetrics"
LABEL org.opencontainers.image.description="zen-metrics sweep worker (v15: v14 + self-destroy CLI + error-trap wrapper)"
LABEL org.opencontainers.image.licenses="AGPL-3.0-or-later"

# Default entrypoint = cvvdp imazen onstart wrapped by the error trap.
# Caller overrides with `--entrypoint /usr/local/bin/onstart_iwssim.sh`
# for the iwssim flow, etc.
ENTRYPOINT ["/usr/local/bin/run_with_error_trap.sh", "/usr/local/bin/onstart_cvvdp_imazen.sh"]

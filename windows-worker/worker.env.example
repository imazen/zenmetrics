# worker.env.example -- config for the Zen idle-only Windows worker.
# Copy to worker.env and fill in. NEVER commit the filled-in worker.env -- it holds R2 credentials.

# Scoped R2 credentials. Mint short-TTL, prefix-scoped temp creds (see README "Credentials");
# NEVER put the account root key on a kid's PC. AWS_SESSION_TOKEN is required for temp creds.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# R2 endpoint + bucket + the shared pool runlist (the same job pool the cloud fleet works).
ZEN_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
ZEN_BUCKET=zentrain
ZEN_POOL_RUNLIST=s3://zentrain/jobs/_pool/runlist.tsv

# CPU budget: worker threads (default = half the logical cores). Lower is gentler on the machine.
ZEN_THREADS=4
